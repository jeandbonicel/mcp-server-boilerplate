# Server
MCP_SERVER_NAME=mcp-server
MCP_SERVER_VERSION=1.0.0

# HTTP Transport
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=127.0.0.1

# Logging
LOG_LEVEL=info

# Authentication (none | api-key | oauth)
MCP_AUTH_MODE=none

# API Key auth — comma-separated list of valid keys
# MCP_API_KEYS=key1,key2,key3

# JWT/OAuth auth
# MCP_JWT_ISSUER=https://auth.example.com
# MCP_JWT_AUDIENCE=mcp-server
# MCP_JWT_SECRET=your-shared-secret
# MCP_JWKS_URI=https://auth.example.com/.well-known/jwks.json
